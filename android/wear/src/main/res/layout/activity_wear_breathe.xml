<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0C"
    android:gravity="center"
    android:padding="16dp">

    <TextView
        android:id="@+id/phase_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_above="@id/count_label"
        android:layout_marginBottom="8dp"
        android:text="Inhale"
        android:textColor="#C8922A"
        android:textSize="14sp"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:fontFamily="sans-serif-light" />

    <TextView
        android:id="@+id/count_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="4"
        android:textColor="#E8EAF0"
        android:textSize="48sp"
        android:fontFamily="sans-serif-thin" />

    <TextView
        android:id="@+id/cycle_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/count_label"
        android:layout_marginTop="8dp"
        android:text="1 / 3"
        android:textColor="#95979f"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:fontFamily="monospace" />

</RelativeLayout>
